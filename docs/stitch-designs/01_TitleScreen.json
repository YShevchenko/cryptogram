{"screenId":"6303fa2b661a412f93992328c352ca8d","projectId":"7392190726270571734","htmlContent":"<html class=\"dark\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"on-tertiary-fixed-variant\": \"#4700a7\",\n            \"outline\": \"#76747b\",\n            \"secondary-fixed-dim\": \"#ffa8e7\",\n            \"tertiary-container\": \"#7000ff\",\n            \"on-secondary-container\": \"#fff5f8\",\n            \"background\": \"#0e0e13\",\n            \"error\": \"#ff716c\",\n            \"inverse-primary\": \"#006c53\",\n            \"on-surface\": \"#f9f5fd\",\n            \"tertiary-fixed\": \"#bda1ff\",\n            \"on-tertiary-fixed\": \"#1f0052\",\n            \"surface-container-high\": \"#1f1f26\",\n            \"on-tertiary\": \"#290067\",\n            \"tertiary-fixed-dim\": \"#b190ff\",\n            \"surface-container\": \"#19191f\",\n            \"surface-variant\": \"#25252d\",\n            \"error-container\": \"#9f0519\",\n            \"on-secondary-fixed-variant\": \"#950085\",\n            \"on-surface-variant\": \"#acaab1\",\n            \"on-primary\": \"#00654d\",\n            \"primary-fixed\": \"#00fac4\",\n            \"secondary-container\": \"#ad009b\",\n            \"on-secondary-fixed\": \"#640059\",\n            \"surface-dim\": \"#0e0e13\",\n            \"primary-fixed-dim\": \"#00eab7\",\n            \"tertiary\": \"#ac89ff\",\n            \"secondary-fixed\": \"#ffbeeb\",\n            \"inverse-on-surface\": \"#55545b\",\n            \"tertiary-dim\": \"#874cff\",\n            \"surface-container-lowest\": \"#000000\",\n            \"on-error-container\": \"#ffa8a3\",\n            \"secondary-dim\": \"#ff59e3\",\n            \"on-primary-fixed\": \"#004534\",\n            \"on-tertiary-container\": \"#f8f1ff\",\n            \"on-primary-container\": \"#005b46\",\n            \"secondary\": \"#ff59e3\",\n            \"primary\": \"#a9ffdf\",\n            \"primary-container\": \"#00fdc6\",\n            \"on-primary-fixed-variant\": \"#00644d\",\n            \"surface-container-low\": \"#131319\",\n            \"error-dim\": \"#d7383b\",\n            \"surface-container-highest\": \"#25252d\",\n            \"surface\": \"#0e0e13\",\n            \"on-background\": \"#f9f5fd\",\n            \"surface-tint\": \"#a9ffdf\",\n            \"primary-dim\": \"#00eab7\",\n            \"surface-bright\": \"#2c2b33\",\n            \"inverse-surface\": \"#fcf8ff\",\n            \"on-secondary\": \"#42003a\",\n            \"on-error\": \"#490006\",\n            \"outline-variant\": \"#48474d\"\n          },\n          fontFamily: {\n            \"headline\": [\"Space Grotesk\"],\n            \"body\": [\"Manrope\"],\n            \"label\": [\"Space Grotesk\"]\n          },\n          borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n        },\n      },\n    }\n  </script>\n<style>\n    .material-symbols-outlined {\n      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n    }\n    .neon-text-glow {\n      text-shadow: 0 0 10px rgba(169, 255, 223, 0.4), 0 0 20px rgba(169, 255, 223, 0.2);\n    }\n    .neon-box-glow {\n      box-shadow: 0 0 20px rgba(0, 255, 200, 0.3), inset 0 0 10px rgba(0, 255, 200, 0.1);\n    }\n    .bg-void {\n      background: radial-gradient(circle at 50% 50%, #19191f 0%, #0e0e13 100%);\n    }\n  </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-void text-on-surface font-body selection:bg-primary selection:text-on-primary-fixed min-h-screen overflow-hidden\">\n<!-- Top Navigation Shell (TopAppBar) -->\n<header class=\"fixed top-0 w-full flex justify-between items-center px-6 h-20 w-full bg-transparent backdrop-blur-md z-50\">\n<div class=\"flex items-center gap-3\">\n<div class=\"w-10 h-10 rounded-full border border-primary/20 flex items-center justify-center overflow-hidden\">\n<img class=\"w-full h-full object-cover\" data-alt=\"digital avatar of a cyberpunk character with neon glowing visor in a dark futuristic setting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB1YLi5Jhk6TJho_4XiToi-68BUQ1E4E-lCA7UOF4lBtcadjGE66GS6jFudN5qJ6vgr9hi4fzqZS7fBy3I53oDSg2qLFwJtGvTnZ2C0hHFoubKpbszD0-bhDHOVCWHQcH4eD7OdVl-ynSnxTYIsJr2abjPKWhWqqdL0i7nwi8-uu9cAPheymcccKHDR8clyaOlJZiabUj8Qd10az-4ZBWHNjWOsMwJ3xBXY4lzAQFW42YAh_AELdMVKGo6HDS2oSuvvfRyasm3bgow\"/>\n</div>\n<span class=\"font-headline tracking-widest uppercase text-[#00FFC8] text-2xl font-bold drop-shadow-[0_0_8px_rgba(0,255,200,0.4)]\">NEON VOID</span>\n</div>\n<button class=\"w-10 h-10 flex items-center justify-center text-[#00FFC8] hover:text-[#a9ffdf] transition-colors active:scale-95 duration-150\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n</button>\n</header>\n<!-- Main Interaction Canvas -->\n<main class=\"relative h-screen w-full flex flex-col items-center justify-center px-8\">\n<!-- Atmospheric Background Decoration -->\n<div class=\"absolute inset-0 pointer-events-none overflow-hidden\">\n<div class=\"absolute top-1/4 -left-20 w-64 h-64 bg-primary/5 rounded-full blur-[100px]\"></div>\n<div class=\"absolute bottom-1/4 -right-20 w-80 h-80 bg-secondary/5 rounded-full blur-[120px]\"></div>\n</div>\n<!-- High Score Display -->\n<div class=\"absolute top-28 flex flex-col items-center gap-1\">\n<span class=\"font-label text-[10px] tracking-[0.2em] text-on-surface-variant uppercase\">GLOBAL STANDING</span>\n<div class=\"flex items-baseline gap-2\">\n<span class=\"font-headline text-sm font-light text-on-surface-variant\">HIGH SCORE:</span>\n<span class=\"font-headline text-2xl font-bold text-primary neon-text-glow tracking-wider\">10,000</span>\n</div>\n</div>\n<!-- Central Hero Action -->\n<div class=\"flex flex-col items-center gap-12 w-full max-w-xs\">\n<!-- Large Glowing Play Button -->\n<div class=\"relative group\">\n<!-- Animated Glow Rings -->\n<div class=\"absolute inset-0 bg-primary/20 rounded-full blur-2xl group-hover:bg-primary/30 transition-all duration-500 scale-125\"></div>\n<button class=\"relative w-48 h-48 rounded-full bg-gradient-to-br from-primary to-primary-container p-1 shadow-[0_0_40px_rgba(0,253,198,0.4)] hover:shadow-[0_0_60px_rgba(0,253,198,0.6)] transition-all duration-300 active:scale-90 flex items-center justify-center\">\n<div class=\"w-full h-full rounded-full bg-surface-container-lowest flex flex-col items-center justify-center border border-primary/20\">\n<span class=\"font-headline text-4xl font-extrabold text-primary tracking-widest ml-2 neon-text-glow\">PLAY</span>\n<span class=\"material-symbols-outlined text-primary text-3xl mt-1\" data-icon=\"play_arrow\" style=\"font-variation-settings: 'FILL' 1;\">play_arrow</span>\n</div>\n</button>\n</div>\n<!-- Session Stats Bento-style small display -->\n<div class=\"grid grid-cols-2 gap-4 w-full\">\n<div class=\"bg-surface-container-low p-4 rounded-xl border border-outline-variant/10 flex flex-col items-center\">\n<span class=\"font-label text-[8px] tracking-widest text-on-surface-variant uppercase mb-1\">RANK</span>\n<span class=\"font-headline text-lg text-secondary neon-text-glow\">#422</span>\n</div>\n<div class=\"bg-surface-container-low p-4 rounded-xl border border-outline-variant/10 flex flex-col items-center\">\n<span class=\"font-label text-[8px] tracking-widest text-on-surface-variant uppercase mb-1\">STREAK</span>\n<span class=\"font-headline text-lg text-tertiary neon-text-glow\">7 DAYS</span>\n</div>\n</div>\n</div>\n<!-- Active Navigation Shell (BottomNavBar) -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#25252d]/60 backdrop-blur-xl rounded-t-xl shadow-[0_-4px_24px_rgba(169,255,223,0.1)]\">\n<a class=\"flex flex-col items-center justify-center text-[#acaab1] py-1 px-4 hover:bg-[#ffffff]/5 transition-all active:scale-90 duration-200\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"shopping_bag\">shopping_bag</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] tracking-[0.1em]\">SHOP</span>\n</a>\n<!-- PLAY is active by intent of a title screen -->\n<a class=\"flex flex-col items-center justify-center text-[#00FFC8] bg-[#00FFC8]/10 rounded-lg py-1 px-4 shadow-[0_0_15px_rgba(0,255,200,0.2)] active:scale-90 duration-200\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"videogame_asset\" style=\"font-variation-settings: 'FILL' 1;\">videogame_asset</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] tracking-[0.1em]\">PLAY</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#acaab1] py-1 px-4 hover:bg-[#ffffff]/5 transition-all active:scale-90 duration-200\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"leaderboard\">leaderboard</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] tracking-[0.1em]\">RANK</span>\n</a>\n</nav>\n</main>\n<!-- Visual Texture Overlay -->\n<div class=\"fixed inset-0 pointer-events-none opacity-[0.03] z-[100]\" style=\"background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA29n7QW9QyVKISGfsGJmUzGsji_FD2bkVev1tCzooXGC62MmErxdAPoN7BtO27xwIi1GH8WBKQmH4_G4AJt-g5KvSytniYdsTecVriKtA1067WDAzLizVz89P