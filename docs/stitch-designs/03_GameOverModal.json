{"screenId":"63e9a5b192714d68ab0da54d3950441b","projectId":"7392190726270571734","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&amp;family=Manrope:wght@200..800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"on-primary-container\": \"#005b46\",\n                        \"on-secondary-container\": \"#fff5f8\",\n                        \"tertiary-dim\": \"#874cff\",\n                        \"inverse-surface\": \"#fcf8ff\",\n                        \"primary-container\": \"#00fdc6\",\n                        \"on-secondary\": \"#42003a\",\n                        \"error\": \"#ff716c\",\n                        \"on-surface-variant\": \"#acaab1\",\n                        \"tertiary-fixed-dim\": \"#b190ff\",\n                        \"surface-bright\": \"#2c2b33\",\n                        \"background\": \"#0e0e13\",\n                        \"outline\": \"#76747b\",\n                        \"on-error\": \"#490006\",\n                        \"outline-variant\": \"#48474d\",\n                        \"surface-container\": \"#19191f\",\n                        \"surface-tint\": \"#a9ffdf\",\n                        \"primary\": \"#a9ffdf\",\n                        \"error-dim\": \"#d7383b\",\n                        \"secondary\": \"#ff59e3\",\n                        \"surface-container-high\": \"#1f1f26\",\n                        \"tertiary-fixed\": \"#bda1ff\",\n                        \"error-container\": \"#9f0519\",\n                        \"primary-dim\": \"#00eab7\",\n                        \"tertiary-container\": \"#7000ff\",\n                        \"tertiary\": \"#ac89ff\",\n                        \"on-background\": \"#f9f5fd\",\n                        \"on-primary-fixed-variant\": \"#00644d\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"surface-dim\": \"#0e0e13\",\n                        \"surface-container-highest\": \"#25252d\",\n                        \"primary-fixed\": \"#00fac4\",\n                        \"on-tertiary-fixed-variant\": \"#4700a7\",\n                        \"secondary-fixed\": \"#ffbeeb\",\n                        \"surface\": \"#0e0e13\",\n                        \"on-tertiary\": \"#290067\",\n                        \"on-secondary-fixed-variant\": \"#950085\",\n                        \"secondary-container\": \"#ad009b\",\n                        \"on-tertiary-container\": \"#f8f1ff\",\n                        \"inverse-primary\": \"#006c53\",\n                        \"primary-fixed-dim\": \"#00eab7\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"secondary-dim\": \"#ff59e3\",\n                        \"on-primary-fixed\": \"#004534\",\n                        \"surface-variant\": \"#25252d\",\n                        \"on-surface\": \"#f9f5fd\",\n                        \"on-primary\": \"#00654d\",\n                        \"surface-container-low\": \"#131319\",\n                        \"inverse-on-surface\": \"#55545b\",\n                        \"on-tertiary-fixed\": \"#1f0052\",\n                        \"on-secondary-fixed\": \"#640059\",\n                        \"secondary-fixed-dim\": \"#ffa8e7\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: { \"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\" },\n                },\n            },\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .neon-glow {\n            text-shadow: 0 0 15px rgba(169, 255, 223, 0.6);\n        }\n        .bg-glass {\n            backdrop-filter: blur(12px);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface antialiased overflow-hidden\">\n<!-- Background Content (Blurred & Darkened) -->\n<div class=\"fixed inset-0 z-0 blur-md brightness-[0.2] pointer-events-none scale-105\">\n<!-- TopAppBar Placeholder for Context -->\n<header class=\"flex justify-between items-center px-6 h-16 w-full fixed top-0 bg-neutral-950/60 backdrop-blur-xl text-[#00FFC8] font-headline tracking-widest uppercase\">\n<span class=\"material-symbols-outlined\">menu</span>\n<span class=\"font-bold tracking-tighter\">VICTORY</span>\n<span class=\"material-symbols-outlined\">settings</span>\n</header>\n<!-- Main Game Background Mockup -->\n<main class=\"h-screen w-full flex flex-col items-center justify-center space-y-8 px-8\">\n<div class=\"grid grid-cols-2 gap-4 w-full\">\n<div class=\"h-40 bg-surface-container-highest rounded-xl\"></div>\n<div class=\"h-40 bg-surface-container-highest rounded-xl\"></div>\n<div class=\"h-40 bg-surface-container-highest rounded-xl\"></div>\n<div class=\"h-40 bg-surface-container-highest rounded-xl\"></div>\n</div>\n<div class=\"w-full h-12 bg-surface-container-lowest rounded-full overflow-hidden\">\n<div class=\"h-full w-2/3 bg-tertiary-container\"></div>\n</div>\n</main>\n<!-- BottomNavBar Placeholder -->\n<nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 py-3 bg-neutral-950/60 backdrop-blur-xl border-t border-white/5\">\n<div class=\"flex flex-col items-center justify-center bg-[#00FFC8]/10 text-[#00FFC8] rounded-xl p-2\"><span class=\"material-symbols-outlined\">home</span></div>\n<div class=\"flex flex-col items-center justify-center text-neutral-500 p-2\"><span class=\"material-symbols-outlined\">leaderboard</span></div>\n<div class=\"flex flex-col items-center justify-center text-neutral-500 p-2\"><span class=\"material-symbols-outlined\">shopping_bag</span></div>\n<div class=\"flex flex-col items-center justify-center text-neutral-500 p-2\"><span class=\"material-symbols-outlined\">person</span></div>\n</nav>\n</div>\n<!-- Modal Overlay -->\n<div class=\"fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-6\">\n<!-- Victory Modal Card -->\n<div class=\"relative w-full max-w-sm bg-surface-container border border-white/5 rounded-xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex flex-col items-center overflow-hidden\">\n<!-- Atmospheric Gradient Glow -->\n<div class=\"absolute -top-24 left-1/2 -translate-x-1/2 w-48 h-48 bg-primary/20 blur-[60px] rounded-full\"></div>\n<!-- Modal Content Content Container -->\n<div class=\"relative z-10 w-full flex flex-col items-center px-8 py-12\">\n<!-- Level Rewards/Stats (Semantic Add-on for Premium feel) -->\n<div class=\"flex space-x-4 mb-8\">\n<div class=\"flex flex-col items-center\">\n<span class=\"label-sm font-label text-on-surface-variant tracking-[0.2em] uppercase text-[10px] mb-1\">XP EARNED</span>\n<span class=\"text-primary font-headline text-2xl font-bold\">+2,400</span>\n</div>\n<div class=\"w-px h-8 bg-outline-variant/30 mt-2\"></div>\n<div class=\"flex flex-col items-center\">\n<span class=\"label-sm font-label text-on-surface-variant tracking-[0.2em] uppercase text-[10px] mb-1\">STREAK</span>\n<span class=\"text-secondary font-headline text-2xl font-bold\">5X</span>\n</div>\n</div>\n<!-- Primary Headline -->\n<h1 class=\"font-headline font-bold text-4xl text-[#00FFC8] uppercase tracking-tighter neon-glow mb-2 text-center\">\n                    Level Complete!\n                </h1>\n<p class=\"font-body text-on-surface-variant text-sm mb-12 text-center uppercase tracking-widest opacity-80\">\n                    Perfect Efficiency Achieved\n                </p>\n<!-- Action Hub -->\n<div class=\"w-full flex flex-col space-y-4\">\n<!-- Massive Primary Button -->\n<button class=\"group relative w-full h-16 flex items-center justify-center bg-gradient-to-r from-primary to-primary-container rounded-md shadow-[0_0_20px_rgba(0,253,198,0.3)] active:scale-[0.98] transition-all duration-200\">\n<span class=\"font-headline font-extrabold text-on-primary-fixed uppercase tracking-wider text-xl\">\n                            Next Level\n                        </span>\n<span class=\"absolute right-4 material-symbols-outlined text-on-primary-fixed font-bold\">chevron_right</span>\n</button>\n<!-- Ad Integration Button -->\n<button class=\"w-full h-14 flex items-center justify-between px-6 bg-surface-container-highest border border-outline-variant/20 rounded-md active:scale-[0.98] transition-all duration-200 group\">\n<div class=\"flex items-center space-y-0 text-primary\">\n<span class=\"material-symbols-outlined mr-3 text-2xl\" style=\"font-variation-settings: 'FILL' 1;\">movie</span>\n<span class=\"font-label text-xs uppercase tracking-widest text-on-surface\">Watch Ad for <span class=\"text-primary font-bold\">+500 Coins</span></span>\n</div>\n</button>\n</div>\n<!-- Secondary Actions / Main Menu Link -->\n<div class=\"mt-12 w-full flex flex-col items-center\">\n<button class=\"font-label text-on-surface-variant hover:text-primary transition-colors text-xs uppercase tracking-[0.25em] active:scale-95 duration-200 py-2\">\n                        Main Menu\n                    </button>\n<!-- Bottom Decorative Pulse -->\n<div class=\"mt-6 w-12 h-1 bg-gradient-to-r from-transparent via-primary/40 to-transparent rounded-full blur-[1px]\"></div>\n</div>\n</div>\n<!-- Corner Accents (High-End Detail) -->\n<div class=\"absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-primary/30 m-2 rounded-tl-sm\"></div>\n<div class=\"absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-primary/30 m-2 rounded-br-sm\"></div>\n</div>\n<!-- Dynamic Content Background Images (Semantic placeholders for modal context) -->\n<div class=\"hidden\">\n<img data-alt=\"close up futuristic glowing microchip patterns on a dark carbon fiber texture background with cyan light streaks\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB71cpTsktiywpXyBanPF-kkbRRAZL4D74X900kUUS0Gp8Lt-Ymax9Dlho_v4z9A2RfEZlOrAnC94IZlMnN8PXSMr9OGK9uyTg6eZYH2gf6tEsuOPcvlCCNg5iVstEL5pe-uImoY4zEWBTt89NadoEc7WGnDk-TOFR7Bo6CW8bMYOpAAYyiVTcWBK-7evmbR92MNOv98cWauWTvvluhA6Gk2oZAO8PIZ66vZJpzlNcmruW2M7uPfZJVmr9iu1MKcw5RsY3XovZ8RVI\"/>\n<img data-alt=\"cinematic shot of a neon city skyline at night through a rainy window with deep magenta and cyan reflections\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCKBarVqTs_j70ZCZbpaMvZbrPJhb5EZYIcdj2BVGwSL_JfoyRZAdCzG7G5j5oQGvYBhS3u4aAAZfB6d_uRD2ZA1lEMQWOJSJzWGLTXoKDH2fe1QxJdmdCuAX2_kj8tOGs5HzrJKjwK0nD_Dzvfnb2gQTv3ikf52t5hqiLtnGuGkCt768KiHNKc9W_SiaXuDiXpBOFqwM3qEKUKqUJvmz7V8jm5e4DcC9XJHd6neJtNkPYAlRnT2Dan43u6_f3d9oxCgK_8BP5kOK8\"/>\n</div>\n</div>\n</body></html>"}
