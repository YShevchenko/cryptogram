{"screenId":"e08257dee46943b7abeb9e41cc81a1f9","projectId":"7392190726270571734","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Neon Void - HUD</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"tertiary-fixed-dim\": \"#b190ff\",\n                        \"surface-variant\": \"#25252d\",\n                        \"surface-container\": \"#19191f\",\n                        \"error-container\": \"#9f0519\",\n                        \"error\": \"#ff716c\",\n                        \"tertiary-fixed\": \"#bda1ff\",\n                        \"on-tertiary-fixed\": \"#1f0052\",\n                        \"on-surface\": \"#f9f5fd\",\n                        \"inverse-primary\": \"#006c53\",\n                        \"surface-container-high\": \"#1f1f26\",\n                        \"on-tertiary\": \"#290067\",\n                        \"tertiary-container\": \"#7000ff\",\n                        \"on-secondary-container\": \"#fff5f8\",\n                        \"background\": \"#0e0e13\",\n                        \"on-tertiary-fixed-variant\": \"#4700a7\",\n                        \"outline\": \"#76747b\",\n                        \"secondary-fixed-dim\": \"#ffa8e7\",\n                        \"surface-dim\": \"#0e0e13\",\n                        \"primary-fixed-dim\": \"#00eab7\",\n                        \"surface-bright\": \"#2c2b33\",\n                        \"inverse-surface\": \"#fcf8ff\",\n                        \"on-secondary\": \"#42003a\",\n                        \"surface-container-low\": \"#131319\",\n                        \"error-dim\": \"#d7383b\",\n                        \"primary\": \"#a9ffdf\",\n                        \"primary-container\": \"#00fdc6\",\n                        \"on-primary\": \"#00654d\",\n                        \"secondary\": \"#ff59e3\",\n                        \"tertiary\": \"#ac89ff\",\n                        \"outline-variant\": \"#48474d\",\n                        \"surface-container-highest\": \"#25252d\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"surface\": \"#0e0e13\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                },\n            },\n        }\n    </script>\n<style>\n        body {\n            background-color: #0e0e13;\n            overflow: hidden;\n            font-family: 'Manrope', sans-serif;\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .hud-scanline {\n            background: linear-gradient(to bottom, transparent 50%, rgba(169, 255, 223, 0.02) 50%);\n            background-size: 100% 4px;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface h-screen w-screen relative select-none\">\n<!-- Gameplay Canvas Simulation -->\n<div class=\"fixed inset-0 z-0 bg-[#0e0e13] flex items-center justify-center overflow-hidden\">\n<div class=\"absolute inset-0 hud-scanline opacity-30\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-t from-surface-container-lowest via-transparent to-transparent opacity-60\"></div>\n<!-- Background Visual Elements for \"Neon Void\" -->\n<div class=\"absolute w-[800px] h-[800px] border border-primary/5 rounded-full blur-3xl opacity-10 animate-pulse\"></div>\n<div class=\"absolute top-1/4 left-1/4 w-32 h-32 bg-primary/20 blur-[120px]\"></div>\n<div class=\"absolute bottom-1/3 right-1/4 w-48 h-48 bg-secondary/10 blur-[100px]\"></div>\n<!-- Empty Central Gameplay Area -->\n<div class=\"relative w-full h-full flex items-center justify-center\">\n<!-- Asymmetric HUD elements (Decorative) -->\n<div class=\"absolute left-12 top-1/2 -translate-y-1/2 flex flex-col gap-8 opacity-20\">\n<div class=\"w-1 h-24 bg-primary/30 rounded-full\"></div>\n<div class=\"w-1 h-12 bg-primary/30 rounded-full\"></div>\n</div>\n<div class=\"absolute right-12 top-1/2 -translate-y-1/2 flex flex-col gap-4 items-end opacity-20\">\n<div class=\"w-16 h-[2px] bg-secondary/40\"></div>\n<div class=\"w-8 h-[2px] bg-secondary/40\"></div>\n</div>\n</div>\n</div>\n<!-- TopAppBar (Transcribed from JSON) -->\n<header class=\"fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-[#0e0e13]/60 backdrop-blur-md shadow-[0_0_20px_rgba(169,255,223,0.1)]\">\n<div class=\"flex items-center gap-4\">\n<button class=\"flex items-center justify-center p-2 text-[#a9ffdf] brightness-125 hover:text-[#00fdc6] hover:scale-105 transition-all active:opacity-80 active:scale-95 duration-100\">\n<span class=\"material-symbols-outlined\">pause</span>\n</button>\n<h1 class=\"font-['Space_Grotesk'] tracking-widest uppercase text-sm font-bold text-[#a9ffdf] drop-shadow-[0_0_8px_rgba(0,255,200,0.4)] text-xl\">LEVEL 42</h1>\n</div>\n<div class=\"flex items-center\">\n<span class=\"font-['Space_Grotesk'] tracking-widest uppercase text-sm text-[#a9ffdf] brightness-125\">SCORE: 24,800</span>\n</div>\n</header>\n<!-- Side Contextual Info (Design System: Asymmetry) -->\n<aside class=\"fixed left-6 top-1/2 -translate-y-1/2 z-40 hidden md:flex flex-col gap-6\">\n<div class=\"bg-surface-container/40 backdrop-blur-lg p-4 rounded-xl border-l-2 border-primary shadow-2xl\">\n<div class=\"text-[10px] font-headline uppercase tracking-widest text-on-surface-variant mb-1\">SYSTEM_STATUS</div>\n<div class=\"flex items-center gap-2\">\n<div class=\"w-2 h-2 rounded-full bg-primary-container animate-pulse shadow-[0_0_8px_#00fdc6]\"></div>\n<span class=\"text-xs font-body font-bold text-on-surface\">NOMINAL</span>\n</div>\n</div>\n</aside>\n<!-- Bottom Action HUD Area -->\n<div class=\"fixed bottom-24 right-8 z-40 flex flex-col items-end gap-4\">\n<!-- Pulse Progress Bar (Special Gaming Component) -->\n<div class=\"w-48\">\n<div class=\"flex justify-between items-end mb-2\">\n<span class=\"text-[10px] font-headline uppercase tracking-tighter text-tertiary\">CORE CHARGE</span>\n<span class=\"text-xs font-headline text-on-surface\">82%</span>\n</div>\n<div class=\"h-2 w-full bg-surface-container-lowest rounded-full overflow-hidden relative\">\n<div class=\"h-full bg-gradient-to-r from-tertiary-dim to-tertiary w-[82%] relative\">\n<div class=\"absolute right-0 top-0 h-full w-[2px] bg-primary shadow-[0_0_10px_#a9ffdf]\"></div>\n</div>\n</div>\n</div>\n</div>\n<!-- BottomNavBar (Transcribed from JSON) -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 bg-[#0e0e13]/80 backdrop-blur-xl border-t border-[#48474d]/20 shadow-[0_-10px_30px_rgba(0,0,0,0.5)] rounded-t-xl\">\n<button class=\"flex flex-col items-center justify-center text-[#acaab1] p-2 hover:bg-[#1f1f26] hover:text-[#f9f5fd] transition-colors active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"inventory_2\">inventory_2</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] uppercase font-bold mt-1\">INVENTORY</span>\n</button>\n<button class=\"flex flex-col items-center justify-center bg-[#a9ffdf]/10 text-[#a9ffdf] rounded-lg p-2 shadow-[0_0_15px_rgba(169,255,223,0.2)] active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"rocket_launch\" style=\"font-variation-settings: 'FILL' 1;\">rocket_launch</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] uppercase font-bold mt-1\">BOOST</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#acaab1] p-2 hover:bg-[#1f1f26] hover:text-[#f9f5fd] transition-colors active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"storefront\">storefront</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] uppercase font-bold mt-1\">STORE</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#acaab1] p-2 hover:bg-[#1f1f26] hover:text-[#f9f5fd] transition-colors active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n<span class=\"font-['Space_Grotesk'] text-[10px] uppercase font-bold mt-1\">CONFIG</span>\n</button>\n</nav>\n<!-- HUD Borders & Frame Accents (Design System: Luminance Layering) -->\n<div class=\"fixed inset-0 pointer-events-none z-10\">\n<!-- Top Left Corner -->\n<div class=\"absolute top-0 left-0 w-24 h-24 border-t-2 border-l-2 border-primary/20 m-4 rounded-tl-xl\"></div>\n<!-- Bottom Right Corner -->\n<div class=\"absolute bottom-0 right-0 w-24 h-24 border-b-2 border-r-2 border-secondary/20 m-4 rounded-br-xl\"></div>\n<!-- Floating Visual Data Points -->\n<div class=\"absolute top-1/3 right-4 opacity-30 flex flex-col items-end\">\n<div class=\"text-[8px] font-headline text-primary-container mb-2\">COORD_X: 231.9</div>\n<div class=\"text-[8px] font-headline text-primary-container mb-2\">COORD_Y: 894.2</div>\n<div class=\"text-[8px] font-headline text-primary-container\">AZIMUTH: 12.5°</div>\n</div>\n</div>\n</body></html>"}
